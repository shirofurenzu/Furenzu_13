# ==============================================
# Furenzu_13 環境變數設定範例
# 請將此檔案複製一份並重新命名為 ".env"
# 然後填入您自己的金鑰與設定值
# ==============================================
# ----------------------------------------------
# 1. 核心設定 (Core)
# ----------------------------------------------
# Discord 機器人的 Token (請至 Discord Developer Portal 取得)
DISCORD_BOT_TOKEN=
# 機器人的 Client ID (應用程式 ID)
DISCORD_CLIENT_ID=
# 伺服器運作 Port (預設 3000)
PORT=3000


# ----------------------------------------------
# 2. AI 模型設定 (AI Models)
# ----------------------------------------------
# AI 機器人模式
# Discord Channel
DISCORD_CHANNEL_CHAT=
DISCORD_CHANNEL_GPT_CHAT=
DISCORD_CHANNEL_GPT_IMAGE=
DISCORD_CHANNEL_GEMINI_CHAT=
DISCORD_CHANNEL_GEMINI_IMAGE=

# Open AI
OPEN_AI_API_KEY=

# Google Gemini API 金鑰(免費)
GEMINI_API_KEY= 

# Google Gemini API 金鑰 圖片專用(付費)
GEMINI_API_KEY_Paid= 


# ----------------------------------------------
# 3. 氣象與第三方服務 (Services)
# ----------------------------------------------
# 中央氣象署 (CWA) API Key (用於查詢台灣天氣)
# 請至 https://opendata.cwa.gov.tw/ 註冊取得

CWB_API_KEY=

# ----------------------------------------------
# 4. 頻道與功能設定 (Channels & Features)
# ----------------------------------------------

# 每日提醒設定(true=開啟, false=關閉，參數可到config\dailyReminders.json設置)
ENABLE_DAILY_REMIND=true
#頻道 ID
DAILY_REMIND_CHANNEL_ID=
#標記使用者ID，多人可用逗號分隔
DAILY_REMIND_USER_ID=

# 每日天氣設定(true=開啟, false=關閉，參數可到config\dailyWeatherTasks.json設置)
ENABLE_DAILY_WEATHER=true
#頻道 ID
DAILY_WEATHER_CHANNEL_ID=

#每日市場資訊(true=開啟, false=關閉，時間可到config\marketHoldings.json設置)
ENABLE_MARKET_REPORT=true
MARKET_REPORT_CHANNEL_ID=

